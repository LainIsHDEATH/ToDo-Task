<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="004-insert-demo-users" author="Ivan" contextFilter="@dev">
        <comment>Insert demo users for local manual testing.</comment>

        <loadData file="data/users.csv"
                  tableName="users"
                  separator=","
                  encoding="UTF-8"
                  relativeToChangelogFile="true">
            <column name="id" type="NUMERIC"/>
            <column name="first_name" type="STRING"/>
            <column name="last_name" type="STRING"/>
            <column name="email" type="STRING"/>
            <column name="password_hash" type="STRING"/>
            <column name="role" type="STRING"/>
        </loadData>

        <sql dbms="postgresql">
            SELECT setval(pg_get_serial_sequence('users', 'id'), (SELECT MAX(id) FROM users));
        </sql>
    </changeSet>

    <changeSet id="004-insert-demo-tasks" author="Ivan" contextFilter="@dev">
        <comment>Insert demo tasks for local manual testing.</comment>

        <loadData file="data/tasks.csv"
                  tableName="tasks"
                  separator=","
                  encoding="UTF-8"
                  relativeToChangelogFile="true">
            <column name="id" type="NUMERIC"/>
            <column name="name" type="STRING"/>
            <column name="priority" type="STRING"/>
            <column name="status" type="STRING"/>
            <column name="owner_user_id" type="NUMERIC"/>
        </loadData>

        <sql dbms="postgresql">
            SELECT setval(pg_get_serial_sequence('tasks', 'id'), (SELECT MAX(id) FROM tasks));
        </sql>
    </changeSet>

    <changeSet id="004-insert-demo-task-collaborators" author="Ivan" contextFilter="@dev">
        <comment>Insert demo task collaborators for local manual testing.</comment>

        <loadData file="data/task-collaborators.csv"
                  tableName="task_collaborators"
                  separator=","
                  encoding="UTF-8"
                  relativeToChangelogFile="true">
            <column name="task_id" type="NUMERIC"/>
            <column name="user_id" type="NUMERIC"/>
        </loadData>
    </changeSet>

</databaseChangeLog>